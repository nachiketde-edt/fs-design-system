{
  "name": "@fs-ds/web-components",
  "version": "0.0.1",
  "description": "FS Design System — framework-agnostic web components built with Lit",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./button": {
      "import": "./dist/components/button/fs-button.js",
      "types": "./dist/components/button/fs-button.d.ts"
    },
    "./input": {
      "import": "./dist/components/input/fs-input.js",
      "types": "./dist/components/input/fs-input.d.ts"
    },
    "./badge": {
      "import": "./dist/components/badge/fs-badge.js",
      "types": "./dist/components/badge/fs-badge.d.ts"
    }
  },
  "files": ["dist", "custom-elements.json"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "analyze": "cem analyze --litelement --globs 'src/**/*.ts'",
    "lint": "eslint src",
    "test": "web-test-runner",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@fs-ds/tokens": "*",
    "lit": "^3.1.3"
  },
  "devDependencies": {
    "@custom-elements-manifest/analyzer": "^0.10.2",
    "@web/test-runner": "^0.19.0",
    "typescript": "*"
  },
  "customElements": "custom-elements.json"
}
