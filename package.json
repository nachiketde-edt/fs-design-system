{
  "name": "fs-design-system",
  "version": "0.0.1",
  "private": true,
  "description": "FS Design System — mono-repo for tokens, web-components, React and Angular packages",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "storybook": "turbo run storybook --filter=@fs-ds/storybook",
    "build-storybook": "turbo run build-storybook --filter=@fs-ds/storybook",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build && changeset publish",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.1",
    "turbo": "^2.0.0",
    "typescript": "^5.4.5",
    "prettier": "^3.2.5",
    "eslint": "^9.2.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "packageManager": "npm@10.5.0"
}
